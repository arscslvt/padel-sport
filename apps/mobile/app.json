{
  "expo": {
    "name": "padel-sport-app",
    "slug": "padel-sport-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "padelsportapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asdpadelsport.padelsportapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.asdpadelsport.padelsportapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-Regular.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-Italic.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-Medium.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-MediumItalic.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-SemiBold.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-SemiBoldItalic.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-Bold.ttf",
            "./assets/fonts/Google_Sans/static/GoogleSans_17pt-BoldItalic.ttf"
          ]
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b4c517c-55e3-48e6-923c-5b0b56ac0309"
      }
    },
    "owner": "arscslvt"
  }
}
